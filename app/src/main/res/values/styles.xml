<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Text appearances: Fraunces for headings, Inter for body, JetBrains Mono for labels/meta -->

    <style name="TextAppearance.GeArt.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/fraunces</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.GeArt.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/fraunces</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.GeArt.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TextAppearance.GeArt.BodyStrong" parent="TextAppearance.GeArt.Body">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.GeArt.Eyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textColor">@color/geart_accent</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.GeArt.Meta" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="android:textColor">@color/geart_pencil</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Buttons -->

    <style name="Widget.GeArt.Button.Ticket" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/geart_accent</item>
        <item name="rippleColor">@color/geart_ink</item>
        <item name="cornerRadius">4dp</item>
        <item name="elevation">0dp</item>
        <item name="android:textColor">@color/geart_ink</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.GeArt.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Inputs -->

    <style name="Widget.GeArt.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/geart_input_stroke</item>
        <item name="hintTextColor">@color/geart_pencil</item>
        <item name="boxCornerRadiusTopStart">4dp</item>
        <item name="boxCornerRadiusTopEnd">4dp</item>
        <item name="boxCornerRadiusBottomStart">4dp</item>
        <item name="boxCornerRadiusBottomEnd">4dp</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <!-- Cards -->

    <style name="Widget.GeArt.CardView" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">4dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

</resources>
