<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llMessageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp"
    android:paddingHorizontal="12dp">

    <LinearLayout
        android:id="@+id/llBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_chat_received"
        android:padding="12dp"
        android:maxWidth="300dp">

        <TextView
            android:id="@+id/tvMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivMessageImage"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="4dp"
            android:background="@color/image_placeholder" />

        <TextView
            android:id="@+id/tvImageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avance del Artista"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6"
            android:textSize="11sp"
            android:visibility="gone"
            android:textStyle="italic" />

        <LinearLayout
            android:id="@+id/llPriceUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Propuesta: $0.0"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAcceptPrice"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Aceptar Precio"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorOnSurface"
        android:alpha="0.4"
        android:textSize="10sp"
        android:layout_marginTop="2dp" />

</LinearLayout>
