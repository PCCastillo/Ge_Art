<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mensajes"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnFilterAll"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Todos"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_chip_selected"
            android:textColor="@android:color/white"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnFilterCommissions"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Comisiones"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_chip_unselected"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnFilterPersonal"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Personales"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_chip_unselected"
            android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.08" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConversations"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
