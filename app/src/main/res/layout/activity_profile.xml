<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/ivProfilePic"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                android:background="@color/image_placeholder"
                android:scaleType="centerCrop"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvRoleAndRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargando perfil..."
                android:textAlignment="center"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDirectCommission"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Solicitar Comisión"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnChat"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="Enviar Mensaje"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre o Seudónimo"
                android:inputType="textPersonName"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/etProfileImageUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Link de foto de perfil (Opcional)"
                android:inputType="textUri"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Biografía o Descripción"
                android:inputType="textMultiLine"
                android:lines="3"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/etSocialLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Redes sociales (Linktree, Twitter, etc.)"
                android:inputType="textUri"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Guardar Cambios"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvDirectRequestsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solicitudes Directas Pendientes"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDirectRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvPortfolioTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trabajos Finalizados"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPortfolio"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOnSurface"
            android:alpha="0.08"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comentarios"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvComments"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <EditText
                android:id="@+id/etNewComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Escribe un comentario..."
                android:inputType="text"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnPostComment"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Publicar Comentario"
            android:textSize="14sp"
            android:textAllCaps="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
