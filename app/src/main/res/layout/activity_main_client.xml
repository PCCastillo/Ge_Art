<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <TextView
        android:id="@+id/tvClientTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GeArt"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/llActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvClientTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnNewCommission"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Nueva Comisión"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnExploreArtists"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="Explorar Artistas"
            android:textSize="13sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton" />
    </LinearLayout>

    <View
        android:id="@+id/dividerActions"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.08"
        app:layout_constraintTop_toBottomOf="@id/llActions" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCommissionsClient"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/dividerActions"
        app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    <View
        android:id="@+id/dividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.08"
        app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnNotifications"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Notificaciones"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6" />

        <TextView
            android:id="@+id/btnChats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Chats"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6" />

        <TextView
            android:id="@+id/btnViewProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Perfil"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Salir"
            android:textSize="12sp"
            android:textColor="@color/blue_primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
