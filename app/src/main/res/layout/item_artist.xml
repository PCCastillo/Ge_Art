<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.GeArt.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivArtistPic"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@color/geart_card_dark"
            android:scaleType="centerCrop"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvArtistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del Artista"
                android:textAppearance="@style/TextAppearance.GeArt.Headline"/>

            <TextView
                android:id="@+id/tvArtistRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⭐ 0.0 (0 reseñas)"
                android:textAppearance="@style/TextAppearance.GeArt.Meta"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnViewArtist"
            style="@style/Widget.GeArt.Button.Outline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/item_view_artist"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
